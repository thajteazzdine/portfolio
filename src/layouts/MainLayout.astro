---
import "../styles/global.css";

interface Props {
	title?: string;
}

const { title = "Azzadine | FPGA and ASIC Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500&display=swap"
		/>
	</head>
	<body>
		<slot />
		<script>
			import "../scripts/main.js";
		</script>
	</body>
</html>
